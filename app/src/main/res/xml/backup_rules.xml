<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude encrypted local SQLite database from unencrypted backups -->
    <exclude domain="database" path="pennywise_database"/>
    <exclude domain="database" path="pennywise_database-wal"/>
    <exclude domain="database" path="pennywise_database-shm"/>
    <!-- Exclude secure database key shared preferences -->
    <exclude domain="sharedpref" path="pennywise_secure_prefs.xml"/>
</full-backup-content>